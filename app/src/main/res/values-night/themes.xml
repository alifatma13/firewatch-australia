<resources>
    <!--
        Dark window-level theme: controls status/nav bar chrome before Compose renders.
        Kept minimal — all real dark theming lives in FireWatchTheme (Compose).
    -->
    <style name="Theme.FireWatch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/sentinel_surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>