<resources>
    <!--
        Window-level theme: controls status/nav bar chrome before Compose renders.
        Kept minimal — all real theming lives in FireWatchTheme (Compose).
    -->
    <style name="Theme.FireWatch" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Match Sentinel base surface so launch screen doesn't flash white/purple -->
        <item name="android:windowBackground">@color/sentinel_surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>